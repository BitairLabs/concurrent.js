{
  "type": "module",
  "scripts": {
    "lint": "npx tsc --noEmit",
    "test:core": "node --test --import @bitair/lift/register test/core/*.ts",
    "test:node": "node --test --import @bitair/lift/register test/node/index.ts",
    "test:bun": "bun test ./test/bun/index.ts",
    "test:deno": "deno test test/deno/index.ts --allow-read",
    "test:c8": "c8 --100 npm test",
    "test": "npm run test:core && npm run test:node && npm run test:deno && npm run test:bun"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/deno": "^2.5.0",
    "@bitair/lift": "^0.3.0",
    "@types/node": "^24.1.0",
    "@types/sinon": "^21.0.1",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "sinon": "^22.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  },
  "license": "MIT"
}
